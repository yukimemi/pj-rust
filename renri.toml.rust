# renri.toml — pj-rust layer. Overwrites pj-base's apm-install
# baseline with a richer post_create hook: cargo make on-add
# refreshes apm skills *and* fetches the upstream remote, so the
# new worktree is rebase-ready without a second command.

[[hooks.post_create]]
type = "command"
run = "cargo make on-add"
shell = "auto"
